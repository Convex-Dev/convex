{
  "name": "dlfs_write",
  "description": "Write content to a file in a DLFS drive. Creates the file if it does not exist, overwrites if it does.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "drive": {
        "type": "string",
        "description": "Drive name"
      },
      "path": {
        "type": "string",
        "description": "File path within the drive"
      },
      "content": {
        "type": "string",
        "description": "Text content to write"
      }
    },
    "required": ["drive", "path", "content"]
  }
}
