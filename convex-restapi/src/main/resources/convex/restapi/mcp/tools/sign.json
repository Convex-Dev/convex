{
  "name": "sign",
  "title": "Value Signer",
  "description": "Sign a value using a provided Ed25519 seed",
  "inputSchema": {
    "type": "object",
    "properties": {
      "value": {
        "type": "string",
        "description": "Value to sign"
      },
      "seed": {
        "type": "string",
        "description": "Ed25519 seed as 64 hex characters"
      }
    },
    "required": ["value", "seed"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "value": {"type": "string"},
      "signature": {"type": "string", "description": "Hex encoded Ed25519 signature"},
      "accountKey": {"type": "string", "description": "Hex encoded public key"},
      "message": {"type": "string", "description": "Optional human-readable message"}
    }
  }
}

